---
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/Hero.astro';
import About from '../components/About.astro';
import Companies from '../components/Companies.astro';
import Timeline from '../components/Timeline.astro';
import News from '../components/News.astro';
import FAQ from '../components/FAQ.astro';
import { organizationSchema, faqSchema } from '../lib/seo';
import { faqs } from '../data/faqs';

const title = 'Premium Holding Company';
const description = 'Masto Holdings is a diversified investment and holding company focused on creating sustainable businesses and delivering long-term value across technology, media, transportation, and more.';

const faqItems = faqs.map(faq => ({
  question: faq.question,
  answer: faq.answer
}));
---

<BaseLayout title={title} description={description}>
  <script type="application/ld+json" set:html={JSON.stringify(organizationSchema)} />
  <script type="application/ld+json" set:html={JSON.stringify(faqSchema(faqItems))} />

  <Hero />
  <About />
  <Companies />
  <Timeline />
  <News />
  <FAQ />

  <section class="cta-final section bg-navy">
    <div class="container text-center">
      <h2 class="section-title text-white" style="color: white;">Ready to Partner With Us?</h2>
      <p class="section-subtitle text-white" style="color: rgba(255, 255, 255, 0.8);">
        We're always looking for strategic partners, investors, and talented individuals to join our mission.
      </p>
      <div style="margin-top: 2rem;">
        <a href="/contact" class="btn btn-primary">Get in Touch</a>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .text-white {
    color: white !important;
  }
</style>
