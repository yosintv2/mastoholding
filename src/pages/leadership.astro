---
import BaseLayout from '../layouts/BaseLayout.astro';
import { leadership } from '../data/leadership';
import { breadcrumbSchema } from '../lib/seo';
import type { TeamMember } from '../types';

const title = 'Leadership';
const description = 'Meet the leadership team of Masto Holdings, experienced executives and visionary leaders driving our portfolio companies.';

const breadcrumbs = [
  { name: 'Home', url: 'https://mastoholdings.com' },
  { name: 'Leadership', url: 'https://mastoholdings.com/leadership' },
];
---

<BaseLayout title={title} description={description} url="https://mastoholdings.com/leadership">
  <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema(breadcrumbs))} />

  <div class="page-header">
    <div class="container">
      <h1>Leadership Team</h1>
      <p>Experienced executives and visionary leaders driving Masto Holdings</p>
    </div>
  </div>

  <section class="section">
    <div class="container">
      <div class="leadership-intro">
        <p>
          Our leadership team brings together decades of combined experience in business, investment, technology, and strategic
          development. Each member is committed to building sustainable, world-class companies that deliver exceptional value.
        </p>
      </div>

      <div class="leadership-grid">
        {leadership.map((member: TeamMember) => (
          <div class="leader-card">
            {member.image && (
              <div class="leader-image">
                <img src={member.image} alt={member.name} />
              </div>
            )}
            <div class="leader-image-placeholder" aria-hidden="true"></div>

            <div class="leader-content">
              <h3>{member.name}</h3>
              <div class="leader-position">{member.position}</div>

              {member.bio && <p class="leader-bio">{member.bio}</p>}

              {member.expertise && member.expertise.length > 0 && (
                <div class="expertise">
                  <strong>Expertise:</strong>
                  <ul class="expertise-list">
                    {member.expertise.map(exp => (
                      <li key={exp}>{exp}</li>
                    ))}
                  </ul>
                </div>
              )}

              {member.socialLinks && (
                <div class="social-links">
                  {member.socialLinks.linkedin && (
                    <a href={member.socialLinks.linkedin} target="_blank" rel="noopener noreferrer" aria-label="LinkedIn">
                      <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor">
                        <path d="M19 3a2 2 0 0 1 2 2v14a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h14m-.5 15.5v-5.3a3.26 3.26 0 0 0-3.26-3.26c-.85 0-1.84.52-2.32 1.39v-1.2h-2.84v8.37h2.84v-4.93c0-.77.62-1.4 1.39-1.4a1.4 1.4 0 0 1 1.4 1.4v4.93h2.84M6.88 8.56a1.68 1.68 0 0 0 1.68-1.68c0-.93-.75-1.69-1.68-1.69a1.69 1.69 0 0 0-1.69 1.69c0 .93.76 1.68 1.69 1.68m1.39 9.94v-8.37H5.5v8.37h2.77z" />
                      </svg>
                    </a>
                  )}
                  {member.socialLinks.twitter && (
                    <a href={member.socialLinks.twitter} target="_blank" rel="noopener noreferrer" aria-label="Twitter">
                      <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor">
                        <path d="M22.46 6c-.85.39-1.78.65-2.73.77 1-6 3.88-1.13 4.27-2.27-1 .59-2.1 1.02-3.28 1.25-.93-1-2.28-1.62-3.76-1.62-2.85 0-5.16 2.31-5.16 5.16 0 .4.05.8.15 1.18-4.3-.22-8.13-2.28-10.7-5.43-.44.77-.7 1.66-.7 2.6 0 1.79.92 3.37 2.32 4.3-.86-.03-1.68-.26-2.39-.65v.07c0 2.5 1.78 4.59 4.14 5.06-.43.12-.89.18-1.36.18-.33 0-.66-.03-.98-.08.66 2.06 2.57 3.56 4.83 3.6-1.77 1.39-4 2.21-6.42 2.21-.42 0-.83-.02-1.24-.07 2.34 1.5 5.12 2.37 8.1 2.37 9.72 0 15.02-8.05 15.02-15.02 0-.23 0-.45-.01-.67.73-.58 1.73-1.31 2.4-2.08z" />
                      </svg>
                    </a>
                  )}
                </div>
              )}
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="section bg-light">
    <div class="container">
      <h2 class="text-center section-title">Our Leadership Philosophy</h2>

      <div class="philosophy-content">
        <p>
          At Masto Holdings, we believe that exceptional leadership is the foundation of exceptional businesses. Our leaders are
          selected not just for their track record of success, but for their commitment to building organizations that prioritize
          long-term value creation, ethical behavior, and positive impact on society.
        </p>
        <p>
          We foster a culture of continuous learning, innovation, and collaboration. Our leaders work together across portfolio
          companies to share best practices, identify synergies, and support each other in achieving ambitious goals.
        </p>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .page-header {
    background: linear-gradient(135deg, var(--color-navy) 0%, var(--color-dark-navy) 100%);
    color: var(--color-white);
    padding: 4rem 0;
    text-align: center;
  }

  .page-header h1 {
    color: var(--color-white);
    font-size: 2.5rem;
    margin-bottom: 0.5rem;
  }

  .page-header p {
    color: rgba(255, 255, 255, 0.8);
    font-size: 1.25rem;
  }

  .leadership-intro {
    text-align: center;
    margin: 2rem 0 4rem;
    max-width: 700px;
    margin-left: auto;
    margin-right: auto;
  }

  .leadership-intro p {
    color: var(--color-gray);
    font-size: 1.1rem;
    line-height: 1.9;
  }

  .leadership-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
    gap: 2.5rem;
    margin: 3rem 0;
  }

  .leader-card {
    background: var(--color-white);
    border-radius: 0.75rem;
    overflow: hidden;
    box-shadow: var(--shadow-md);
    transition: var(--transition);
  }

  .leader-card:hover {
    transform: translateY(-8px);
    box-shadow: var(--shadow-lg);
  }

  .leader-image-placeholder {
    width: 100%;
    height: 280px;
    background: linear-gradient(135deg, var(--color-navy) 0%, var(--color-dark-navy) 100%);
  }

  .leader-image {
    width: 100%;
    height: 280px;
    overflow: hidden;
    background: linear-gradient(135deg, var(--color-navy) 0%, var(--color-dark-navy) 100%);
  }

  .leader-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .leader-content {
    padding: 2rem;
  }

  .leader-content h3 {
    color: var(--color-navy);
    font-size: 1.35rem;
    margin-bottom: 0.5rem;
  }

  .leader-position {
    color: var(--color-gold);
    font-weight: 600;
    font-size: 0.95rem;
    margin-bottom: 1rem;
  }

  .leader-bio {
    color: var(--color-gray);
    line-height: 1.8;
    margin-bottom: 1rem;
    font-size: 0.95rem;
  }

  .expertise {
    margin-bottom: 1.5rem;
  }

  .expertise strong {
    display: block;
    color: var(--color-navy);
    margin-bottom: 0.5rem;
    font-size: 0.95rem;
  }

  .expertise-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
  }

  .expertise-list li {
    background-color: rgba(212, 175, 55, 0.1);
    color: var(--color-gold);
    padding: 0.4rem 0.8rem;
    border-radius: 2rem;
    font-size: 0.8rem;
    font-weight: 600;
  }

  .social-links {
    display: flex;
    gap: 1rem;
  }

  .social-links a {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 36px;
    height: 36px;
    background-color: rgba(212, 175, 55, 0.1);
    color: var(--color-gold);
    border-radius: 50%;
    transition: var(--transition);
    text-decoration: none;
  }

  .social-links a:hover {
    background-color: var(--color-gold);
    color: var(--color-navy);
  }

  .philosophy-content {
    max-width: 800px;
    margin: 2rem auto;
    text-align: center;
  }

  .philosophy-content p {
    color: var(--color-gray);
    font-size: 1.05rem;
    line-height: 1.9;
    margin-bottom: 1.5rem;
  }

  .text-center {
    text-align: center;
  }

  @media (max-width: 768px) {
    .page-header {
      padding: 2rem 0;
    }

    .page-header h1 {
      font-size: 1.75rem;
    }

    .leadership-grid {
      grid-template-columns: 1fr;
      gap: 1.5rem;
    }

    .leader-card {
      margin-bottom: 1rem;
    }
  }
</style>
