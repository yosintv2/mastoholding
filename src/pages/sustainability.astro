---
import BaseLayout from '../layouts/BaseLayout.astro';
import { breadcrumbSchema } from '../lib/seo';

const title = 'Sustainability & ESG';
const description = 'Masto Holdings commitment to environmental responsibility, social impact, and governance excellence across all portfolio companies.';

const breadcrumbs = [
  { name: 'Home', url: 'https://mastoholdings.com' },
  { name: 'Sustainability', url: 'https://mastoholdings.com/sustainability' },
];
---

<BaseLayout title={title} description={description} url="https://mastoholdings.com/sustainability">
  <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema(breadcrumbs))} />

  <div class="page-header">
    <div class="container">
      <h1>Sustainability & ESG</h1>
      <p>Building businesses that create long-term value with minimal environmental impact</p>
    </div>
  </div>

  <section class="section">
    <div class="container">
      <div class="section-header text-center">
        <h2 class="section-title">Our ESG Framework</h2>
        <p class="section-subtitle">
          Environmental, Social, and Governance principles are core to how we operate and invest
        </p>
      </div>

      <div class="esg-grid">
        <div class="esg-card">
          <div class="esg-icon">🌍</div>
          <h3>Environmental</h3>
          <p>We are committed to reducing our carbon footprint, promoting renewable energy, and supporting circular economy initiatives across our portfolio companies.</p>
          <ul class="esg-list">
            <li>Carbon emission reduction targets</li>
            <li>Renewable energy investments</li>
            <li>Waste management and recycling</li>
            <li>Water conservation programs</li>
            <li>Climate resilience planning</li>
          </ul>
        </div>

        <div class="esg-card">
          <div class="esg-icon">🤝</div>
          <h3>Social</h3>
          <p>We prioritize employee wellbeing, diversity & inclusion, community development, and positive social impact across all our businesses.</p>
          <ul class="esg-list">
            <li>Fair wages and benefits</li>
            <li>Diversity and inclusion programs</li>
            <li>Employee development and training</li>
            <li>Community engagement</li>
            <li>Supply chain responsibility</li>
          </ul>
        </div>

        <div class="esg-card">
          <div class="esg-icon">📊</div>
          <h3>Governance</h3>
          <p>We maintain the highest standards of corporate governance, transparency, and ethical business practices across our organization.</p>
          <ul class="esg-list">
            <li>Board diversity and independence</li>
            <li>Transparent reporting</li>
            <li>Risk management frameworks</li>
            <li>Ethical business practices</li>
            <li>Stakeholder engagement</li>
          </ul>
        </div>
      </div>
    </div>
  </section>

  <section class="section bg-light">
    <div class="container">
      <h2 class="text-center section-title">Our Sustainability Goals</h2>

      <div class="goals-grid">
        <div class="goal-item">
          <div class="goal-number">2030</div>
          <div class="goal-description">
            <strong>Carbon Neutral Operations</strong>
            <p>Achieve net-zero carbon emissions across all portfolio companies through efficiency improvements and renewable energy adoption.</p>
          </div>
        </div>

        <div class="goal-item">
          <div class="goal-number">50%</div>
          <div class="goal-description">
            <strong>Renewable Energy</strong>
            <p>Transition 50% of energy consumption to renewable sources across operations.</p>
          </div>
        </div>

        <div class="goal-item">
          <div class="goal-number">100%</div>
          <div class="goal-description">
            <strong>Waste Reduction</strong>
            <p>Achieve zero waste to landfill in all major facilities through comprehensive recycling and reuse programs.</p>
          </div>
        </div>

        <div class="goal-item">
          <div class="goal-number">5000+</div>
          <div class="goal-description">
            <strong>Lives Impacted</strong>
            <p>Create positive social impact touching over 5000 lives through community programs and employment.</p>
          </div>
        </div>

        <div class="goal-item">
          <div class="goal-number">40%</div>
          <div class="goal-description">
            <strong>Women in Leadership</strong>
            <p>Ensure women comprise 40% of leadership positions across all companies by 2030.</p>
          </div>
        </div>

        <div class="goal-item">
          <div class="goal-number">100%</div>
          <div class="goal-description">
            <strong>Transparent Reporting</strong>
            <p>Comprehensive ESG reporting and annual sustainability reviews published for all stakeholders.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <h2 class="text-center section-title">Our Commitments</h2>

      <div class="commitments">
        <div class="commitment">
          <h3>Environmental Responsibility</h3>
          <p>
            Every portfolio company must develop an environmental action plan aligned with global sustainability standards. We invest in
            renewable energy, waste reduction, and water conservation initiatives.
          </p>
        </div>

        <div class="commitment">
          <h3>Fair Labor Practices</h3>
          <p>
            We ensure all employees receive fair compensation, safe working conditions, and opportunities for professional development.
            We prohibit child labor and forced labor in all supply chains.
          </p>
        </div>

        <div class="commitment">
          <h3>Community Investment</h3>
          <p>
            We invest in local communities through education programs, healthcare initiatives, and economic development projects that
            create sustainable livelihoods.
          </p>
        </div>

        <div class="commitment">
          <h3>Ethical Governance</h3>
          <p>
            We maintain transparent governance structures with independent oversight, regular audits, and comprehensive compliance
            programs across all portfolio companies.
          </p>
        </div>

        <div class="commitment">
          <h3>Stakeholder Engagement</h3>
          <p>
            We actively engage with employees, customers, communities, and investors to understand their concerns and incorporate
            feedback into our sustainability strategies.
          </p>
        </div>

        <div class="commitment">
          <h3>Continuous Improvement</h3>
          <p>
            We regularly assess our ESG performance, set ambitious targets, and implement improvements across all areas. Annual
            sustainability reports provide transparent updates on our progress.
          </p>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .page-header {
    background: linear-gradient(135deg, var(--color-navy) 0%, var(--color-dark-navy) 100%);
    color: var(--color-white);
    padding: 4rem 0;
    text-align: center;
  }

  .page-header h1 {
    color: var(--color-white);
    font-size: 2.5rem;
    margin-bottom: 0.5rem;
  }

  .page-header p {
    color: rgba(255, 255, 255, 0.8);
    font-size: 1.25rem;
  }

  .esg-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
    gap: 2rem;
    margin: 3rem 0;
  }

  .esg-card {
    background: var(--color-white);
    padding: 2.5rem;
    border-radius: 0.75rem;
    box-shadow: var(--shadow-md);
    border-top: 4px solid var(--color-gold);
    transition: var(--transition);
  }

  .esg-card:hover {
    transform: translateY(-8px);
    box-shadow: var(--shadow-lg);
  }

  .esg-icon {
    font-size: 3rem;
    margin-bottom: 1rem;
    display: block;
  }

  .esg-card h3 {
    color: var(--color-navy);
    margin-bottom: 1rem;
    font-size: 1.5rem;
  }

  .esg-card p {
    color: var(--color-gray);
    line-height: 1.8;
    margin-bottom: 1.5rem;
  }

  .esg-list {
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .esg-list li {
    color: var(--color-gray);
    padding: 0.5rem 0 0.5rem 1.5rem;
    position: relative;
  }

  .esg-list li::before {
    content: '✓';
    position: absolute;
    left: 0;
    color: var(--color-gold);
    font-weight: bold;
  }

  .goals-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: 2rem;
    margin: 3rem 0;
  }

  .goal-item {
    background: var(--color-white);
    padding: 2rem;
    border-radius: 0.75rem;
    box-shadow: var(--shadow-sm);
    display: flex;
    gap: 1.5rem;
    transition: var(--transition);
  }

  .goal-item:hover {
    box-shadow: var(--shadow-md);
  }

  .goal-number {
    font-size: 2.5rem;
    font-weight: 700;
    color: var(--color-gold);
    font-family: var(--font-serif);
    min-width: 80px;
    text-align: center;
  }

  .goal-description strong {
    display: block;
    color: var(--color-navy);
    margin-bottom: 0.5rem;
    font-size: 1rem;
  }

  .goal-description p {
    color: var(--color-gray);
    font-size: 0.95rem;
    line-height: 1.6;
    margin: 0;
  }

  .commitments {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
    gap: 2rem;
    margin: 3rem 0;
  }

  .commitment {
    background: var(--color-white);
    padding: 2rem;
    border-radius: 0.75rem;
    box-shadow: var(--shadow-md);
    border-left: 4px solid var(--color-gold);
    transition: var(--transition);
  }

  .commitment:hover {
    transform: translateY(-4px);
    box-shadow: var(--shadow-lg);
  }

  .commitment h3 {
    color: var(--color-navy);
    margin-bottom: 1rem;
    font-size: 1.25rem;
  }

  .commitment p {
    color: var(--color-gray);
    line-height: 1.8;
    margin: 0;
  }

  .text-center {
    text-align: center;
  }

  @media (max-width: 768px) {
    .page-header {
      padding: 2rem 0;
    }

    .page-header h1 {
      font-size: 1.75rem;
    }

    .esg-grid {
      grid-template-columns: 1fr;
      gap: 1.5rem;
    }

    .goals-grid {
      grid-template-columns: 1fr;
      gap: 1.5rem;
    }

    .goal-item {
      flex-direction: column;
      align-items: center;
      text-align: center;
    }

    .goal-number {
      min-width: auto;
    }

    .commitments {
      grid-template-columns: 1fr;
      gap: 1.5rem;
    }
  }
</style>
