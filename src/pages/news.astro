---
import BaseLayout from '../layouts/BaseLayout.astro';
import { blogPosts } from '../data/blog';
import { breadcrumbSchema } from '../lib/seo';
import type { BlogPost } from '../types';

const title = 'News & Insights';
const description = 'Latest news, insights, and articles from Masto Holdings about investments, technology, business, and market trends.';

const breadcrumbs = [
  { name: 'Home', url: 'https://mastoholdings.com' },
  { name: 'News', url: 'https://mastoholdings.com/news' },
];
---

<BaseLayout title={title} description={description} url="https://mastoholdings.com/news">
  <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema(breadcrumbs))} />

  <div class="page-header">
    <div class="container">
      <h1>News & Insights</h1>
      <p>Latest updates, market analysis, and thought leadership from Masto Holdings</p>
    </div>
  </div>

  <section class="section">
    <div class="container">
      <div class="news-listing">
        {blogPosts.map((post: BlogPost) => (
          <article class="news-list-item">
            <div class="news-list-content">
              <div class="news-meta">
                <span class="news-category">{post.category}</span>
                <span class="news-date">
                  {post.publishedDate.toLocaleDateString('en-US', {
                    year: 'numeric',
                    month: 'short',
                    day: 'numeric',
                  })}
                </span>
              </div>

              <h2>
                <a href={`/news/${post.slug}`}>{post.title}</a>
              </h2>

              <p class="excerpt">{post.excerpt}</p>

              <div class="news-footer">
                <span class="author">{post.author}</span>
                <a href={`/news/${post.slug}`} class="read-more">Read Full Article →</a>
              </div>
            </div>
          </article>
        ))}
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .page-header {
    background: linear-gradient(135deg, var(--color-navy) 0%, var(--color-dark-navy) 100%);
    color: var(--color-white);
    padding: 4rem 0;
    text-align: center;
  }

  .page-header h1 {
    color: var(--color-white);
    font-size: 2.5rem;
    margin-bottom: 0.5rem;
  }

  .page-header p {
    color: rgba(255, 255, 255, 0.8);
    font-size: 1.25rem;
  }

  .news-listing {
    max-width: 800px;
    margin: 3rem auto;
  }

  .news-list-item {
    padding: 2rem 0;
    border-bottom: 1px solid rgba(10, 31, 68, 0.1);
    transition: var(--transition);
  }

  .news-list-item:last-child {
    border-bottom: none;
  }

  .news-list-item:hover {
    background-color: rgba(212, 175, 55, 0.02);
    padding-left: 1rem;
    padding-right: 1rem;
    margin-left: -1rem;
    margin-right: -1rem;
  }

  .news-meta {
    display: flex;
    gap: 1rem;
    align-items: center;
    margin-bottom: 1rem;
    flex-wrap: wrap;
  }

  .news-category {
    display: inline-block;
    background-color: rgba(212, 175, 55, 0.1);
    color: var(--color-gold);
    padding: 0.35rem 0.75rem;
    border-radius: 2rem;
    font-size: 0.75rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.5px;
  }

  .news-date {
    font-size: 0.85rem;
    color: var(--color-gray);
    font-weight: 500;
  }

  .news-list-item h2 {
    color: var(--color-navy);
    font-size: 1.75rem;
    margin: 0 0 0.75rem 0;
    line-height: 1.4;
  }

  .news-list-item h2 a {
    color: var(--color-navy);
    text-decoration: none;
    transition: var(--transition);
  }

  .news-list-item h2 a:hover {
    color: var(--color-gold);
  }

  .excerpt {
    color: var(--color-gray);
    font-size: 1rem;
    line-height: 1.8;
    margin-bottom: 1.5rem;
  }

  .news-footer {
    display: flex;
    justify-content: space-between;
    align-items: center;
    flex-wrap: wrap;
    gap: 1rem;
  }

  .author {
    color: var(--color-gray);
    font-size: 0.9rem;
    font-weight: 500;
  }

  .read-more {
    color: var(--color-gold);
    font-weight: 600;
    text-decoration: none;
    transition: var(--transition);
  }

  .read-more:hover {
    color: var(--color-light-gold);
    transform: translateX(4px);
    display: inline-block;
  }

  @media (max-width: 768px) {
    .page-header {
      padding: 2rem 0;
    }

    .page-header h1 {
      font-size: 1.75rem;
    }

    .news-list-item {
      padding: 1.5rem 0;
    }

    .news-list-item:hover {
      padding-left: 0;
      padding-right: 0;
      margin-left: 0;
      margin-right: 0;
    }

    .news-list-item h2 {
      font-size: 1.35rem;
    }

    .news-footer {
      flex-direction: column;
      align-items: flex-start;
    }
  }
</style>
