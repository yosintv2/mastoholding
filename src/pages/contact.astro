---
import BaseLayout from '../layouts/BaseLayout.astro';
import { breadcrumbSchema } from '../lib/seo';

const title = 'Contact Us';
const description = 'Get in touch with Masto Holdings for partnership opportunities, inquiries, and more. We\'d love to hear from you.';

const breadcrumbs = [
  { name: 'Home', url: 'https://mastoholdings.com' },
  { name: 'Contact', url: 'https://mastoholdings.com/contact' },
];
---

<BaseLayout title={title} description={description} url="https://mastoholdings.com/contact">
  <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema(breadcrumbs))} />

  <div class="page-header">
    <div class="container">
      <h1>Get in Touch</h1>
      <p>We'd love to hear from you. Reach out with your inquiries, partnerships, or feedback.</p>
    </div>
  </div>

  <section class="section">
    <div class="container contact-container">
      <div class="contact-info">
        <h2>Contact Information</h2>

        <div class="info-cards">
          <div class="info-card">
            <div class="info-icon">📧</div>
            <h3>Email</h3>
            <p>
              <a href="mailto:contact@mastoholdings.com">contact@mastoholdings.com</a>
            </p>
            <p class="info-detail">General inquiries and partnerships</p>
          </div>

          <div class="info-card">
            <div class="info-icon">📞</div>
            <h3>Phone</h3>
            <p>
              <a href="tel:+977123456789">+977 (0) 1 234 5678</a>
            </p>
            <p class="info-detail">Monday - Friday, 9 AM - 5 PM NST</p>
          </div>

          <div class="info-card">
            <div class="info-icon">📍</div>
            <h3>Address</h3>
            <p>
              Masto Holdings<br />
              Nepal
            </p>
            <p class="info-detail">Headquarters</p>
          </div>

          <div class="info-card">
            <div class="info-icon">💼</div>
            <h3>Careers</h3>
            <p>
              <a href="mailto:careers@mastoholdings.com">careers@mastoholdings.com</a>
            </p>
            <p class="info-detail">Job opportunities and internships</p>
          </div>
        </div>

        <div class="social-section">
          <h3>Follow Us</h3>
          <div class="social-icons">
            <a href="https://linkedin.com/company/mastoholdings" target="_blank" rel="noopener noreferrer" aria-label="LinkedIn">
              <svg width="24" height="24" viewBox="0 0 24 24" fill="currentColor">
                <path d="M19 3a2 2 0 0 1 2 2v14a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h14m-.5 15.5v-5.3a3.26 3.26 0 0 0-3.26-3.26c-.85 0-1.84.52-2.32 1.39v-1.2h-2.84v8.37h2.84v-4.93c0-.77.62-1.4 1.39-1.4a1.4 1.4 0 0 1 1.4 1.4v4.93h2.84M6.88 8.56a1.68 1.68 0 0 0 1.68-1.68c0-.93-.75-1.69-1.68-1.69a1.69 1.69 0 0 0-1.69 1.69c0 .93.76 1.68 1.69 1.68m1.39 9.94v-8.37H5.5v8.37h2.77z"/>
              </svg>
            </a>
            <a href="https://twitter.com/mastoholdings" target="_blank" rel="noopener noreferrer" aria-label="Twitter">
              <svg width="24" height="24" viewBox="0 0 24 24" fill="currentColor">
                <path d="M22.46 6c-.85.39-1.78.65-2.73.77 1-6 3.88-1.13 4.27-2.27-1 .59-2.1 1.02-3.28 1.25-.93-1-2.28-1.62-3.76-1.62-2.85 0-5.16 2.31-5.16 5.16 0 .4.05.8.15 1.18-4.3-.22-8.13-2.28-10.7-5.43-.44.77-.7 1.66-.7 2.6 0 1.79.92 3.37 2.32 4.3-.86-.03-1.68-.26-2.39-.65v.07c0 2.5 1.78 4.59 4.14 5.06-.43.12-.89.18-1.36.18-.33 0-.66-.03-.98-.08.66 2.06 2.57 3.56 4.83 3.6-1.77 1.39-4 2.21-6.42 2.21-.42 0-.83-.02-1.24-.07 2.34 1.5 5.12 2.37 8.1 2.37 9.72 0 15.02-8.05 15.02-15.02 0-.23 0-.45-.01-.67.73-.58 1.73-1.31 2.4-2.08z"/>
              </svg>
            </a>
          </div>
        </div>
      </div>

      <form class="contact-form" action="/api/contact" method="POST">
        <h2>Send us a Message</h2>

        <div class="form-group">
          <label for="name">Full Name *</label>
          <input type="text" id="name" name="name" required />
        </div>

        <div class="form-group">
          <label for="email">Email Address *</label>
          <input type="email" id="email" name="email" required />
        </div>

        <div class="form-group">
          <label for="phone">Phone Number</label>
          <input type="tel" id="phone" name="phone" />
        </div>

        <div class="form-group">
          <label for="company">Company</label>
          <input type="text" id="company" name="company" />
        </div>

        <div class="form-group">
          <label for="subject">Subject *</label>
          <select id="subject" name="subject" required>
            <option value="">Select a subject</option>
            <option value="general">General Inquiry</option>
            <option value="partnership">Partnership Opportunity</option>
            <option value="investment">Investment Inquiry</option>
            <option value="media">Media & Press</option>
            <option value="careers">Career Opportunity</option>
            <option value="other">Other</option>
          </select>
        </div>

        <div class="form-group">
          <label for="message">Message *</label>
          <textarea id="message" name="message" rows="6" required></textarea>
        </div>

        <div class="form-group checkbox">
          <label for="privacy">
            <input type="checkbox" id="privacy" name="privacy" required />
            I agree to the privacy policy and terms of service
          </label>
        </div>

        <button type="submit" class="btn btn-primary">Send Message</button>
      </form>
    </div>
  </section>

  <section class="section bg-light">
    <div class="container">
      <h2 class="text-center section-title">Office Locations</h2>

      <div class="locations-grid">
        <div class="location-card">
          <h3>Headquarters</h3>
          <p>
            <strong>Kathmandu, Nepal</strong><br />
            Our main office and corporate headquarters
          </p>
          <p class="contact-detail">
            <a href="mailto:contact@mastoholdings.com">contact@mastoholdings.com</a>
          </p>
        </div>

        <div class="location-card">
          <h3>Regional Office</h3>
          <p>
            <strong>Nepal</strong><br />
            Supporting operations across the region
          </p>
          <p class="contact-detail">
            <a href="tel:+977123456789">+977 (0) 1 234 5678</a>
          </p>
        </div>

        <div class="location-card">
          <h3>Coming Soon</h3>
          <p>
            <strong>International Expansion</strong><br />
            Additional offices opening in major markets
          </p>
          <p class="contact-detail">Stay tuned for announcements</p>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .page-header {
    background: linear-gradient(135deg, var(--color-navy) 0%, var(--color-dark-navy) 100%);
    color: var(--color-white);
    padding: 4rem 0;
    text-align: center;
  }

  .page-header h1 {
    color: var(--color-white);
    font-size: 2.5rem;
    margin-bottom: 0.5rem;
  }

  .page-header p {
    color: rgba(255, 255, 255, 0.8);
    font-size: 1.25rem;
  }

  .contact-container {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 4rem;
    margin: 3rem 0;
  }

  .contact-info h2,
  .contact-form h2 {
    color: var(--color-navy);
    font-size: 1.75rem;
    margin-bottom: 2rem;
  }

  .info-cards {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
    gap: 1.5rem;
    margin-bottom: 3rem;
  }

  .info-card {
    background: var(--color-light-gray);
    padding: 1.5rem;
    border-radius: 0.75rem;
    text-align: center;
    transition: var(--transition);
  }

  .info-card:hover {
    transform: translateY(-4px);
    box-shadow: var(--shadow-md);
  }

  .info-icon {
    font-size: 2.5rem;
    margin-bottom: 0.75rem;
  }

  .info-card h3 {
    color: var(--color-navy);
    margin-bottom: 0.75rem;
    font-size: 1.1rem;
  }

  .info-card p {
    color: var(--color-gray);
    margin: 0 0 0.5rem 0;
  }

  .info-card a {
    color: var(--color-gold);
    font-weight: 600;
    text-decoration: none;
  }

  .info-detail {
    color: var(--color-gray);
    font-size: 0.85rem !important;
    font-weight: 400;
  }

  .social-section {
    background: var(--color-white);
    padding: 1.5rem;
    border-radius: 0.75rem;
    border: 1px solid rgba(10, 31, 68, 0.1);
  }

  .social-section h3 {
    color: var(--color-navy);
    margin-bottom: 1rem;
  }

  .social-icons {
    display: flex;
    gap: 1.5rem;
  }

  .social-icons a {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 44px;
    height: 44px;
    background-color: rgba(212, 175, 55, 0.1);
    color: var(--color-gold);
    border-radius: 50%;
    transition: var(--transition);
    text-decoration: none;
  }

  .social-icons a:hover {
    background-color: var(--color-gold);
    color: var(--color-navy);
  }

  .contact-form {
    background: var(--color-white);
    padding: 2rem;
    border-radius: 0.75rem;
    box-shadow: var(--shadow-md);
  }

  .form-group {
    margin-bottom: 1.5rem;
  }

  .form-group label {
    display: block;
    color: var(--color-navy);
    font-weight: 600;
    margin-bottom: 0.5rem;
  }

  .form-group input,
  .form-group select,
  .form-group textarea {
    width: 100%;
    padding: 0.75rem;
    border: 1px solid rgba(10, 31, 68, 0.2);
    border-radius: 0.5rem;
    font-family: var(--font-sans);
    font-size: 1rem;
    transition: var(--transition);
  }

  .form-group input:focus,
  .form-group select:focus,
  .form-group textarea:focus {
    outline: none;
    border-color: var(--color-gold);
    box-shadow: 0 0 0 3px rgba(212, 175, 55, 0.1);
  }

  .form-group.checkbox {
    display: flex;
    align-items: center;
  }

  .form-group.checkbox label {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    margin-bottom: 0;
  }

  .form-group.checkbox input {
    width: auto;
  }

  .locations-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: 2rem;
    margin: 3rem 0;
  }

  .location-card {
    background: var(--color-white);
    padding: 2rem;
    border-radius: 0.75rem;
    box-shadow: var(--shadow-sm);
    border-left: 4px solid var(--color-gold);
    transition: var(--transition);
  }

  .location-card:hover {
    transform: translateY(-4px);
    box-shadow: var(--shadow-md);
  }

  .location-card h3 {
    color: var(--color-navy);
    margin-bottom: 1rem;
    font-size: 1.25rem;
  }

  .location-card p {
    color: var(--color-gray);
    line-height: 1.7;
    margin-bottom: 0.75rem;
  }

  .contact-detail {
    color: var(--color-gold);
    font-weight: 600;
  }

  .contact-detail a {
    color: var(--color-gold);
    text-decoration: none;
  }

  .text-center {
    text-align: center;
  }

  @media (max-width: 1024px) {
    .contact-container {
      grid-template-columns: 1fr;
      gap: 2rem;
    }

    .info-cards {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 768px) {
    .page-header {
      padding: 2rem 0;
    }

    .page-header h1 {
      font-size: 1.75rem;
    }

    .info-cards {
      grid-template-columns: 1fr;
      gap: 1rem;
    }

    .contact-form {
      padding: 1.5rem;
    }

    .locations-grid {
      grid-template-columns: 1fr;
      gap: 1.5rem;
    }
  }
</style>
