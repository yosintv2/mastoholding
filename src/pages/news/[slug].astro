---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { blogPosts, getPostBySlug } from '../../data/blog';
import { articleSchema, breadcrumbSchema } from '../../lib/seo';
import type { BlogPost } from '../../types';

export function getStaticPaths() {
  return blogPosts.map(post => ({
    params: { slug: post.slug },
    props: { post },
  }));
}

interface Props {
  post: BlogPost;
}

const { post } = Astro.props;

if (!post) {
  return Astro.redirect('/news');
}

const breadcrumbs = [
  { name: 'Home', url: 'https://mastoholdings.com' },
  { name: 'News', url: 'https://mastoholdings.com/news' },
  { name: post.title, url: `https://mastoholdings.com/news/${post.slug}` },
];

const schema = articleSchema({
  title: post.title,
  description: post.excerpt,
  image: post.image,
  author: post.author,
  publishedDate: post.publishedDate.toISOString(),
  url: `https://mastoholdings.com/news/${post.slug}`,
});
---

<BaseLayout
  title={post.title}
  description={post.excerpt}
  image={post.image}
  url={`https://mastoholdings.com/news/${post.slug}`}
>
  <script type="application/ld+json" set:html={JSON.stringify(schema)} />
  <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema(breadcrumbs))} />

  <article class="blog-post">
    <div class="post-header">
      <div class="container">
        <div class="post-meta">
          <span class="category">{post.category}</span>
          <span class="date">
            {post.publishedDate.toLocaleDateString('en-US', {
              year: 'numeric',
              month: 'long',
              day: 'numeric',
            })}
          </span>
        </div>
        <h1>{post.title}</h1>
        <p class="post-excerpt">{post.excerpt}</p>
        <div class="post-author">
          By <strong>{post.author}</strong>
        </div>
      </div>
    </div>

    <div class="post-content">
      <div class="container">
        <div class="article-body">
          <div set:html={post.content} />
        </div>

        <aside class="post-sidebar">
          <div class="post-info">
            <h3>Article Info</h3>
            <dl>
              <dt>Published:</dt>
              <dd>
                {post.publishedDate.toLocaleDateString('en-US', {
                  year: 'numeric',
                  month: 'long',
                  day: 'numeric',
                })}
              </dd>
              <dt>Category:</dt>
              <dd>{post.category}</dd>
              {post.tags && (
                <>
                  <dt>Tags:</dt>
                  <dd>
                    {post.tags.map(tag => (
                      <span class="tag" key={tag}>{tag}</span>
                    ))}
                  </dd>
                </>
              )}
            </dl>
          </div>
        </aside>
      </div>
    </div>

    <div class="related-articles">
      <div class="container">
        <h2>More Articles</h2>
        <div class="related-grid">
          {blogPosts
            .filter(p => p.category === post.category && p.slug !== post.slug)
            .slice(0, 3)
            .map(relatedPost => (
              <div class="related-card">
                <span class="related-category">{relatedPost.category}</span>
                <h3><a href={`/news/${relatedPost.slug}`}>{relatedPost.title}</a></h3>
                <p>{relatedPost.excerpt}</p>
                <a href={`/news/${relatedPost.slug}`} class="related-link">Read More →</a>
              </div>
            ))}
        </div>
      </div>
    </div>
  </article>
</BaseLayout>

<style>
  .blog-post {
    min-height: 100vh;
  }

  .post-header {
    background: linear-gradient(135deg, var(--color-navy) 0%, var(--color-dark-navy) 100%);
    color: var(--color-white);
    padding: 4rem 0;
  }

  .post-meta {
    display: flex;
    gap: 1rem;
    align-items: center;
    margin-bottom: 1.5rem;
    flex-wrap: wrap;
  }

  .category {
    display: inline-block;
    background-color: rgba(212, 175, 55, 0.2);
    color: var(--color-gold);
    padding: 0.5rem 1rem;
    border-radius: 2rem;
    font-size: 0.85rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.5px;
  }

  .date {
    font-size: 0.95rem;
    color: rgba(255, 255, 255, 0.7);
  }

  .post-header h1 {
    color: var(--color-white);
    font-size: 2.75rem;
    line-height: 1.3;
    margin-bottom: 1rem;
  }

  .post-excerpt {
    font-size: 1.25rem;
    color: rgba(255, 255, 255, 0.9);
    margin-bottom: 1.5rem;
    line-height: 1.6;
  }

  .post-author {
    color: rgba(255, 255, 255, 0.8);
  }

  .post-content {
    padding: 4rem 0;
  }

  .container {
    display: grid;
    grid-template-columns: 1fr 300px;
    gap: 3rem;
    align-items: start;
  }

  .article-body {
    line-height: 1.9;
    color: var(--color-gray);
    font-size: 1.05rem;
  }

  .article-body :global(p) {
    margin-bottom: 1.5rem;
  }

  .article-body :global(h2) {
    margin-top: 2rem;
    margin-bottom: 1rem;
    color: var(--color-navy);
    font-size: 1.75rem;
  }

  .article-body :global(h3) {
    margin-top: 1.5rem;
    margin-bottom: 0.75rem;
    color: var(--color-navy);
  }

  .article-body :global(ul),
  .article-body :global(ol) {
    margin-bottom: 1.5rem;
    padding-left: 2rem;
  }

  .article-body :global(li) {
    margin-bottom: 0.5rem;
  }

  .post-sidebar {
    position: sticky;
    top: 100px;
  }

  .post-info {
    background: var(--color-light-gray);
    padding: 1.5rem;
    border-radius: 0.75rem;
    border-left: 4px solid var(--color-gold);
  }

  .post-info h3 {
    color: var(--color-navy);
    margin-bottom: 1rem;
    font-size: 1.1rem;
  }

  .post-info dl {
    margin: 0;
    padding: 0;
  }

  .post-info dt {
    color: var(--color-navy);
    font-weight: 600;
    margin-top: 1rem;
    margin-bottom: 0.25rem;
    font-size: 0.9rem;
  }

  .post-info dt:first-child {
    margin-top: 0;
  }

  .post-info dd {
    color: var(--color-gray);
    margin: 0;
    margin-bottom: 0.5rem;
    font-size: 0.95rem;
  }

  .tag {
    display: inline-block;
    background-color: rgba(212, 175, 55, 0.1);
    color: var(--color-gold);
    padding: 0.3rem 0.6rem;
    border-radius: 2rem;
    font-size: 0.8rem;
    margin-right: 0.5rem;
    margin-bottom: 0.5rem;
  }

  .related-articles {
    background: var(--color-light-gray);
    padding: 4rem 0;
    margin-top: 4rem;
    border-top: 2px solid rgba(10, 31, 68, 0.1);
  }

  .related-articles h2 {
    color: var(--color-navy);
    margin-bottom: 2rem;
    text-align: center;
  }

  .related-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
    gap: 2rem;
  }

  .related-card {
    background: var(--color-white);
    padding: 1.5rem;
    border-radius: 0.75rem;
    box-shadow: var(--shadow-sm);
    transition: var(--transition);
  }

  .related-card:hover {
    transform: translateY(-4px);
    box-shadow: var(--shadow-md);
  }

  .related-category {
    display: inline-block;
    background-color: rgba(212, 175, 55, 0.1);
    color: var(--color-gold);
    padding: 0.3rem 0.6rem;
    border-radius: 2rem;
    font-size: 0.75rem;
    font-weight: 600;
    margin-bottom: 0.75rem;
  }

  .related-card h3 {
    color: var(--color-navy);
    margin-bottom: 0.75rem;
    font-size: 1.1rem;
    line-height: 1.3;
  }

  .related-card h3 a {
    color: var(--color-navy);
    text-decoration: none;
  }

  .related-card h3 a:hover {
    color: var(--color-gold);
  }

  .related-card p {
    color: var(--color-gray);
    font-size: 0.9rem;
    margin-bottom: 1rem;
  }

  .related-link {
    color: var(--color-gold);
    font-weight: 600;
    text-decoration: none;
  }

  .related-link:hover {
    color: var(--color-light-gold);
  }

  @media (max-width: 1024px) {
    .container {
      grid-template-columns: 1fr;
      gap: 2rem;
    }

    .post-sidebar {
      position: static;
    }
  }

  @media (max-width: 768px) {
    .post-header {
      padding: 2rem 0;
    }

    .post-header h1 {
      font-size: 1.75rem;
    }

    .post-excerpt {
      font-size: 1rem;
    }

    .post-content {
      padding: 2rem 0;
    }

    .article-body {
      font-size: 1rem;
    }

    .related-articles {
      padding: 2rem 0;
    }

    .related-grid {
      grid-template-columns: 1fr;
      gap: 1.5rem;
    }
  }
</style>
