---
import { faqs } from '../data/faqs';
import type { FAQItem } from '../types';
---

<section class="faq section bg-light" id="faq">
  <div class="container">
    <div class="section-header text-center">
      <h2 class="section-title">Frequently Asked Questions</h2>
      <p class="section-subtitle">Everything you need to know about Masto Holdings</p>
    </div>

    <div class="faq-container">
      {faqs.map((faq: FAQItem, index: number) => (
        <details class="faq-item" open={index === 0}>
          <summary class="faq-question">
            <span>{faq.question}</span>
            <svg class="faq-icon" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <path d="M6 9l6 6 6-6"></path>
            </svg>
          </summary>
          <div class="faq-answer">
            <p>{faq.answer}</p>
          </div>
        </details>
      ))}
    </div>
  </div>
</section>

<style>
  .faq-container {
    max-width: 800px;
    margin: 3rem auto;
  }

  .faq-item {
    margin-bottom: 1.5rem;
  }

  .faq-question {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 1.5rem;
    background: var(--color-white);
    border: 2px solid rgba(10, 31, 68, 0.1);
    border-radius: 0.5rem;
    cursor: pointer;
    transition: var(--transition);
    font-weight: 600;
    color: var(--color-navy);
    font-size: 1.05rem;
    list-style: none;
    user-select: none;
  }

  .faq-question::-webkit-details-marker {
    display: none;
  }

  .faq-question:hover {
    border-color: var(--color-gold);
    background-color: rgba(212, 175, 55, 0.02);
  }

  .faq-item[open] > .faq-question {
    border-color: var(--color-gold);
    color: var(--color-gold);
  }

  .faq-icon {
    flex-shrink: 0;
    width: 24px;
    height: 24px;
    color: var(--color-gold);
    transition: var(--transition);
    transform: rotate(0deg);
  }

  .faq-item[open] .faq-icon {
    transform: rotate(180deg);
  }

  .faq-answer {
    padding: 0 1.5rem 1.5rem;
    animation: slideDown 0.3s ease-out;
  }

  .faq-answer p {
    color: var(--color-gray);
    line-height: 1.8;
    margin: 0;
    font-size: 0.975rem;
  }

  @keyframes slideDown {
    from {
      opacity: 0;
      transform: translateY(-10px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  @media (max-width: 768px) {
    .faq-question {
      padding: 1.25rem;
      font-size: 1rem;
    }

    .faq-answer {
      padding: 0 1.25rem 1.25rem;
    }

    .faq-icon {
      width: 20px;
      height: 20px;
    }
  }
</style>

<script>
  // Ensure proper details/summary behavior
  const details = document.querySelectorAll('details');
  details.forEach(detail => {
    const summary = detail.querySelector('summary');
    if (summary) {
      summary.addEventListener('click', (e) => {
        e.preventDefault();
        detail.open = !detail.open;
      });
    }
  });
</script>
