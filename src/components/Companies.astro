---
import { companies } from '../data/companies';
import type { Company } from '../types';

const featuredCompanies = companies.filter(c => c.featured);
---

<section class="companies section" id="companies">
  <div class="container">
    <div class="section-header text-center">
      <h2 class="section-title">Our Companies & Brands</h2>
      <p class="section-subtitle">A diversified portfolio spanning technology, media, beverages, transportation, sports, and more</p>
    </div>

    <div class="companies-grid">
      {featuredCompanies.map((company: Company) => (
        <div class="company-card">
          <div class="company-badge">{company.sector}</div>
          <h3>{company.name}</h3>
          <p>{company.description}</p>
          <div class="company-meta">
            {company.established && <span class="meta-tag">Est. {company.established}</span>}
            <a href={company.website || '/companies'} class="company-link">Learn More →</a>
          </div>
        </div>
      ))}
    </div>

    <div class="companies-cta text-center">
      <p>Explore all {companies.length} portfolio companies</p>
      <a href="/companies" class="btn btn-secondary">View All Companies</a>
    </div>
  </div>
</section>

<style>
  .companies-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(320px, 1fr));
    gap: 2rem;
    margin: 3rem 0;
  }

  .company-card {
    background: var(--color-white);
    border: 1px solid rgba(10, 31, 68, 0.1);
    border-radius: 0.75rem;
    padding: 2rem;
    transition: var(--transition);
    position: relative;
    overflow: hidden;
  }

  .company-card::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 4px;
    background: linear-gradient(90deg, var(--color-gold) 0%, var(--color-accent) 100%);
    transform: scaleX(0);
    transform-origin: left;
    transition: var(--transition);
  }

  .company-card:hover {
    border-color: var(--color-gold);
    box-shadow: var(--shadow-lg);
    transform: translateY(-4px);
  }

  .company-card:hover::before {
    transform: scaleX(1);
  }

  .company-badge {
    display: inline-block;
    background-color: rgba(212, 175, 55, 0.1);
    color: var(--color-gold);
    padding: 0.5rem 1rem;
    border-radius: 2rem;
    font-size: 0.85rem;
    font-weight: 600;
    margin-bottom: 1rem;
  }

  .company-card h3 {
    color: var(--color-navy);
    margin-bottom: 0.75rem;
    font-size: 1.35rem;
  }

  .company-card p {
    color: var(--color-gray);
    line-height: 1.8;
    margin-bottom: 1.5rem;
    min-height: 72px;
  }

  .company-meta {
    display: flex;
    justify-content: space-between;
    align-items: center;
    flex-wrap: wrap;
    gap: 1rem;
    padding-top: 1rem;
    border-top: 1px solid rgba(10, 31, 68, 0.05);
  }

  .meta-tag {
    font-size: 0.85rem;
    color: var(--color-gray);
    font-weight: 500;
  }

  .company-link {
    color: var(--color-gold);
    font-weight: 600;
    text-decoration: none;
    transition: var(--transition);
  }

  .company-link:hover {
    color: var(--color-light-gold);
    transform: translateX(4px);
    display: inline-block;
  }

  .companies-cta {
    margin-top: 4rem;
    padding-top: 2rem;
    border-top: 2px solid rgba(10, 31, 68, 0.1);
  }

  .companies-cta p {
    font-size: 1.125rem;
    color: var(--color-navy);
    margin-bottom: 1.5rem;
    font-weight: 500;
  }

  @media (max-width: 768px) {
    .companies-grid {
      grid-template-columns: 1fr;
      gap: 1.5rem;
    }

    .company-card {
      padding: 1.5rem;
    }
  }
</style>
