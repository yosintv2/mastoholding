---
import { getFeaturedPosts } from '../data/blog';
import type { BlogPost } from '../types';

const featuredPosts = getFeaturedPosts();
---

<section class="news section">
  <div class="container">
    <div class="section-header text-center">
      <h2 class="section-title">News & Insights</h2>
      <p class="section-subtitle">Latest updates from Masto Holdings and the markets we serve</p>
    </div>

    <div class="news-grid">
      {featuredPosts.map((post: BlogPost) => (
        <article class="news-card">
          {post.image && (
            <div class="news-image">
              <img src={post.image} alt={post.title} loading="lazy" />
            </div>
          )}
          <div class="news-content">
            <div class="news-meta">
              <span class="news-category">{post.category}</span>
              <span class="news-date">
                {post.publishedDate.toLocaleDateString('en-US', {
                  year: 'numeric',
                  month: 'short',
                  day: 'numeric',
                })}
              </span>
            </div>
            <h3 class="news-title">{post.title}</h3>
            <p class="news-excerpt">{post.excerpt}</p>
            <a href={`/news/${post.slug}`} class="news-link">Read Article →</a>
          </div>
        </article>
      ))}
    </div>

    <div class="news-cta text-center">
      <a href="/news" class="btn btn-secondary">View All Articles</a>
    </div>
  </div>
</section>

<style>
  .news-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(320px, 1fr));
    gap: 2rem;
    margin: 3rem 0;
  }

  .news-card {
    background: var(--color-white);
    border-radius: 0.75rem;
    overflow: hidden;
    box-shadow: var(--shadow-md);
    transition: var(--transition);
    display: flex;
    flex-direction: column;
    height: 100%;
  }

  .news-card:hover {
    transform: translateY(-8px);
    box-shadow: var(--shadow-lg);
  }

  .news-image {
    width: 100%;
    height: 200px;
    overflow: hidden;
    background: linear-gradient(135deg, var(--color-navy) 0%, var(--color-dark-navy) 100%);
  }

  .news-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: var(--transition);
  }

  .news-card:hover .news-image img {
    transform: scale(1.05);
  }

  .news-content {
    padding: 2rem;
    display: flex;
    flex-direction: column;
    flex-grow: 1;
  }

  .news-meta {
    display: flex;
    gap: 1rem;
    align-items: center;
    margin-bottom: 1rem;
    flex-wrap: wrap;
  }

  .news-category {
    display: inline-block;
    background-color: rgba(212, 175, 55, 0.1);
    color: var(--color-gold);
    padding: 0.35rem 0.75rem;
    border-radius: 2rem;
    font-size: 0.75rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.5px;
  }

  .news-date {
    font-size: 0.85rem;
    color: var(--color-gray);
    font-weight: 500;
  }

  .news-title {
    color: var(--color-navy);
    font-size: 1.35rem;
    margin-bottom: 0.75rem;
    line-height: 1.4;
  }

  .news-excerpt {
    color: var(--color-gray);
    font-size: 0.95rem;
    line-height: 1.7;
    margin-bottom: 1.5rem;
    flex-grow: 1;
  }

  .news-link {
    color: var(--color-gold);
    font-weight: 600;
    text-decoration: none;
    transition: var(--transition);
    align-self: flex-start;
  }

  .news-link:hover {
    color: var(--color-light-gold);
    transform: translateX(4px);
    display: inline-block;
  }

  .news-cta {
    margin-top: 2rem;
  }

  @media (max-width: 768px) {
    .news-grid {
      grid-template-columns: 1fr;
      gap: 1.5rem;
    }

    .news-content {
      padding: 1.5rem;
    }

    .news-title {
      font-size: 1.2rem;
    }
  }
</style>
